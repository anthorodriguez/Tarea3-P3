@model List<TaskManager.Models.Task>
@{
    ViewData["Title"] = "Gestión de Tareas";
    var stats = ViewBag.Stats;
}

<!-- Header Section -->
<div class="header-section">
    <h1 class="header-title">
        <i class="fas fa-tasks"></i> Gestión Inteligente de Tareas
    </h1>
    <p class="header-subtitle">Organiza, prioriza y completa tus tareas de manera eficiente</p>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="stats-card">
            <i class="fas fa-list-ul fa-2x mb-2"></i>
            <h3>@stats.Item1</h3>
            <p class="mb-0">Total</p>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--success-color), #059669);">
            <i class="fas fa-check-circle fa-2x mb-2"></i>
            <h3>@stats.Item2</h3>
            <p class="mb-0">Completadas</p>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--warning-color), #d97706);">
            <i class="fas fa-clock fa-2x mb-2"></i>
            <h3>@stats.Item3</h3>
            <p class="mb-0">Pendientes</p>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stats-card" style="background: linear-gradient(135deg, var(--danger-color), #dc2626);">
            <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
            <h3>@stats.Item4</h3>
            <p class="mb-0">Alta Prioridad</p>
        </div>
    </div>
</div>

<!-- Action Buttons -->
<div class="row mb-4">
    <div class="col-md-6">
        <button class="btn btn-primary-custom btn-custom w-100" data-bs-toggle="modal" data-bs-target="#createTaskModal">
            <i class="fas fa-plus"></i> Nueva Tarea
        </button>
    </div>
    <div class="col-md-6">
        <button class="btn btn-outline-primary btn-custom w-100" data-bs-toggle="collapse" data-bs-target="#searchSection">
            <i class="fas fa-search"></i> Buscar y Filtrar
        </button>
    </div>
</div>

<!-- Search and Filter Section -->
<div class="collapse mb-4" id="searchSection">
    <div class="card">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="search" class="form-control form-control-custom" 
                           placeholder="Buscar tareas..." value="@ViewBag.Search">
                </div>
                <div class="col-md-4">
                    <select name="sort" class="form-select form-control-custom">
                        <option value="">Ordenar por...</option>
                        <option value="title" selected="@(ViewBag.Sort == "title")">Título</option>
                        <option value="date" selected="@(ViewBag.Sort == "date")">Fecha</option>
                        <option value="priority" selected="@(ViewBag.Sort == "priority")">Prioridad</option>
                        <option value="status" selected="@(ViewBag.Sort == "status")">Estado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary-custom btn-custom w-100">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Tasks List -->
<div class="row">
    @if (Model.Any())
    {
        @foreach (var task in Model)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card task-card priority-@task.Priority.ToString().ToLower() @(task.IsCompleted ? "completed-task" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title @(task.IsCompleted ? "text-decoration-line-through" : "")">
                                @if (task.IsCompleted)
                                {
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                }
                                else
                                {
                                    <i class="far fa-circle me-2"></i>
                                }
                                @task.Title
                            </h5>
                            <span class="badge bg-@(task.Priority == TaskManager.Models.Priority.Alta ? "danger" : 
                                                   task.Priority == TaskManager.Models.Priority.Media ? "warning" : "success")">
                                @task.Priority
                            </span>
                        </div>
                        
                        <p class="card-text text-muted">@task.Description</p>
                        
                        <small class="text-muted">
                            <i class="fas fa-calendar-alt"></i> @task.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </small>
                        
                        <div class="mt-3">
                            <form method="post" class="d-inline">
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" asp-action="Complete" 
                                        class="btn btn-sm @(task.IsCompleted ? "btn-outline-secondary" : "btn-success") me-1">
                                    <i class="fas fa-@(task.IsCompleted ? "undo" : "check")"></i>
                                </button>
                            </form>
                            
                            <button class="btn btn-sm btn-outline-primary me-1" 
                                    data-bs-toggle="modal" data-bs-target="#editTaskModal@(task.Id)">
                                <i class="fas fa-edit"></i>
                            </button>
                            
                            <form method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro?')">
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" asp-action="Delete" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Edit Task Modal -->
            <div class="modal fade" id="editTaskModal@(task.Id)" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Editar Tarea</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form method="post" asp-action="Update">
                            <div class="modal-body">
                                <input type="hidden" name="id" value="@task.Id" />
                                <div class="mb-3">
                                    <label class="form-label">Título</label>
                                    <input type="text" name="title" class="form-control form-control-custom" 
                                           value="@task.Title" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Descripción</label>
                                    <textarea name="description" class="form-control form-control-custom" 
                                              rows="3">@task.Description</textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Prioridad</label>
                                    <select name="priority" class="form-select form-control-custom">
                                        <option value="1" selected="@(task.Priority == TaskManager.Models.Priority.Baja)">Baja</option>
                                        <option value="2" selected="@(task.Priority == TaskManager.Models.Priority.Media)">Media</option>
                                        <option value="3" selected="@(task.Priority == TaskManager.Models.Priority.Alta)">Alta</option>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn btn-primary-custom">Guardar Cambios</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="text-center py-5">
                <i class="fas fa-tasks fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">No hay tareas</h4>
                <p class="text-muted">¡Crea tu primera tarea para comenzar!</p>
                <button class="btn btn-primary-custom btn-custom" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                    <i class="fas fa-plus"></i> Nueva Tarea
                </button>
            </div>
        </div>
    }
</div>

<!-- Create Task Modal -->
<div class="modal fade" id="createTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-plus text-primary"></i> Nueva Tarea
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createTaskForm" onsubmit="return createTask(event)">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Título *</label>
                        <input type="text" name="title" class="form-control form-control-custom" 
                               placeholder="Ingresa el título de la tarea" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea name="description" class="form-control form-control-custom" 
                                  rows="3" placeholder="Describe los detalles de la tarea"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Prioridad</label>
                        <select name="priority" class="form-select form-control-custom">
                            <option value="1">🟢 Baja</option>
                            <option value="2" selected>🟡 Media</option>
                            <option value="3">🔴 Alta</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="fas fa-save"></i> Crear Tarea
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add this script at the end of the file -->
<script>
    // Initialize modal and form
    let createTaskModal = null;
    let createTaskForm = null;

    document.addEventListener('DOMContentLoaded', function() {
        createTaskModal = new bootstrap.Modal(document.getElementById('createTaskModal'));
        createTaskForm = document.getElementById('createTaskForm');
    });

    function createTask(event) {
        event.preventDefault();
        
        // Clear any previous errors
        const errorElements = document.querySelectorAll('.text-danger');
        errorElements.forEach(el => el.remove());

        // Get form data
        const formData = new FormData(createTaskForm);
        
        // Convert priority value to enum
        const priority = parseInt(formData.get('priority'));
        formData.set('priority', priority);

        // Submit the form via AJAX
        fetch('/Home/Create', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Close the modal properly
                createTaskModal.hide();
                // Reset the form
                createTaskForm.reset();
                // Refresh the page
                location.reload();
            } else {
                // Display error message
                const errorDiv = document.createElement('div');
                errorDiv.className = 'text-danger mt-2';
                errorDiv.textContent = data.message;
                createTaskForm.querySelector('.modal-body').appendChild(errorDiv);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            // Display error message
            const errorDiv = document.createElement('div');
            errorDiv.className = 'text-danger mt-2';
            errorDiv.textContent = 'Error al crear la tarea. Por favor, intenta de nuevo.';
            createTaskForm.querySelector('.modal-body').appendChild(errorDiv);
        });

        return false;
    }

    // Handle modal shown event
    document.getElementById('createTaskModal').addEventListener('shown.bs.modal', function () {
        createTaskForm.reset();
    });

    // Handle modal hidden event
    document.getElementById('createTaskModal').addEventListener('hidden.bs.modal', function () {
        createTaskForm.reset();
        // Remove any error messages
        const errorElements = document.querySelectorAll('.text-danger');
        errorElements.forEach(el => el.remove());
    });
</script>
        </div>
    </div>
</div>